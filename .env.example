# Primos NFT Website Environment Variables

# Stripe (for card payments)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Solana
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
VITE_MERCHANT_WALLET=your_solana_wallet_address_for_payments

# Magic Eden (optional - for higher rate limits)
VITE_MAGIC_EDEN_API_KEY=your_magic_eden_api_key

# Collection Info
VITE_COLLECTION_SYMBOL=primos

# --- Discord bot (server-side; set in Vercel, NOT prefixed with VITE_) ---
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_PUBLIC_KEY=your_app_public_key
DISCORD_APP_ID=your_application_id
DISCORD_GUILD_ID=1277996118059253821
DISCORD_MOD_ROLE_ID=your_mod_role_id
ANNOUNCE_CHANNEL_ID=channel_id
LINKS_CHANNEL_ID=channel_id
STATS_CHANNEL_ID=channel_id
SALES_CHANNEL_ID=channel_id
CRON_SECRET=long_random_string
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Holder verification (custom Helius bot) ---
# Helius free-tier API key (https://helius.dev) — DAS searchAssets counts holdings
HELIUS_API_KEY=your_helius_api_key
# Primos verified on-chain collection address (Metaplex collection mint)
PRIMOS_COLLECTION_ADDRESS=primos_collection_mint_address
# Tier role IDs on the new guild — Primos held: 1 / 5 / 10 / 25
TIER_ROLE_PRIMO=role_id
TIER_ROLE_COMPADRE=role_id
TIER_ROLE_TIO=role_id
TIER_ROLE_ELJEFE=role_id
# Public base URL of the site, used to build the /verify link (defaults to the vercel app)
PUBLIC_BASE_URL=https://primos-site.vercel.app
